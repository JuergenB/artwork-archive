    {
      "parameters": {
        "jsCode": "const e=$input.first().json;const ex=e.execution||{};const wf=e.workflow||{};const err=ex.error||{};let cn=null;let ae=null;const rd=(ex.data||{}).resultData||{};const run=rd.runData||{};const ep=run['Notification Email Prep for Admins and Submitter'];if(ep&&ep[0]&&ep[0].data&&ep[0].data.main){const i=ep[0].data.main[0];if(i&&i[0])ae=i[0].json['Admin Notification Email Addresses']||null;}const cd=run['Search Existing Campaigns'];if(cd&&cd[0]&&cd[0].data&&cd[0].data.main){const i=cd[0].data.main[0];if(i&&i[0]){cn=i[0].json['Campaign Name']||null;if(!ae){const ce=i[0].json['Campaign Contact Emails']||null;if(ce)ae=String(ce).split(',').map(x=>x.trim()).filter(x=>x).join(', ');}}}const ca=run['Capture Artist & Campaign Data'];if(!cn&&ca&&ca[0]&&ca[0].data&&ca[0].data.main){const i=ca[0].data.main[0];if(i&&i[0])cn=i[0].json.campaign||null;}const u='https://polymash.app.n8n.cloud';const eu=ex.id?`${u}/workflow/${wf.id}/executions/${ex.id}`:u;return[{json:{workflowName:wf.name||'Unknown',workflowId:wf.id||'',executionId:ex.id||'',executionUrl:eu,errorMessage:err.message||'Unknown error',errorNode:ex.lastNodeExecuted||'Unknown',errorTimestamp:new Date().toISOString(),campaignName:cn,adminEmails:ae,hasAdminEmails:!!ae}}];"
      },
