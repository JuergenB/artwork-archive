    {
      "parameters": {
        "jsCode": "const d=$input.first().json;\nconst subject=`\\u26a0\\ufe0f Workflow Error: ${d.workflowName} \\u2014 ${d.errorNode}`;\nconst body=`<div style=\"font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;max-width:600px;margin:0 auto\"><div style=\"background:#dc3545;color:#fff;padding:20px;border-radius:8px 8px 0 0\"><h2 style=\"margin:0\">\\u26a0\\ufe0f Workflow Error Alert</h2><p style=\"margin:5px 0 0;opacity:.9\">${d.workflowName}</p></div><div style=\"background:#fff;border:1px solid #ddd;border-top:none;padding:20px;border-radius:0 0 8px 8px\"><table style=\"width:100%;border-collapse:collapse\"><tr><td style=\"padding:8px 0;color:#666;width:140px\">Failed Node:</td><td style=\"padding:8px 0;font-weight:600\">${d.errorNode}</td></tr><tr><td style=\"padding:8px 0;color:#666\">Error:</td><td style=\"padding:8px 0;color:#dc3545\">${d.errorMessage}</td></tr><tr><td style=\"padding:8px 0;color:#666\">Execution ID:</td><td style=\"padding:8px 0\">${d.executionId}</td></tr><tr><td style=\"padding:8px 0;color:#666\">Timestamp:</td><td style=\"padding:8px 0\">${d.errorTimestamp}</td></tr><tr><td style=\"padding:8px 0;color:#666\">Campaign:</td><td style=\"padding:8px 0\">${d.campaignName||'N/A'}</td></tr><tr><td style=\"padding:8px 0;color:#666\">Email Source:</td><td style=\"padding:8px 0;font-style:italic\">${d.emailSource}</td></tr></table><div style=\"margin-top:20px;text-align:center\"><a href=\"${d.executionUrl}\" style=\"display:inline-block;background:#dc3545;color:#fff;padding:12px 24px;border-radius:6px;text-decoration:none;font-weight:600\">View Failed Execution</a></div></div><p style=\"text-align:center;color:#999;font-size:12px;margin-top:15px\">Sent by AA Rolling Submissions Error Handler</p></div>`;\nreturn[{json:{...d,emailSubject:subject,emailBody:body}}];"
      },
